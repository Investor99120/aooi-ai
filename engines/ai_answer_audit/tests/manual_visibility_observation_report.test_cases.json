{
  "test_cases": [
    {
      "name": "reads manual snapshots",
      "expected": {
        "snapshots_observed_min": 1
      }
    },
    {
      "name": "requires import gate report",
      "expected": {
        "required_input": "manual_snapshot_import_gate_report.json"
      }
    },
    {
      "name": "does not generate final visibility score",
      "expected": {
        "final_visibility_score_generated": false
      }
    },
    {
      "name": "does not generate share of voice score",
      "expected": {
        "share_of_voice_score_generated": false
      }
    },
    {
      "name": "does not treat AI answers as verified facts",
      "expected": {
        "ai_answers_treated_as_verified_fact": false
      }
    },
    {
      "name": "does not generate customer-facing claims",
      "expected": {
        "customer_facing_claims_generated": false
      }
    },
    {
      "name": "brand_mentions observed but not overclaimed",
      "expected": {
        "population_level_claim": false
      }
    },
    {
      "name": "brand_recommendations observed but not overclaimed",
      "expected": {
        "statistically_representative": false
      }
    },
    {
      "name": "zero brand mentions classifies as visibility_absent or content_opportunity",
      "expected": {
        "allowed_classifications": [
          "visibility_absent_sample",
          "content_opportunity_sample"
        ]
      }
    },
    {
      "name": "strong category framing classifies as content_opportunity_sample",
      "expected": {
        "observation_classification": "content_opportunity_sample"
      }
    },
    {
      "name": "claim_risk_notes are carried into risk observation",
      "expected": {
        "risk_notes_summary_min": 1
      }
    },
    {
      "name": "Gemini high-risk language is flagged",
      "expected": {
        "high_risk_surfaces_contains": "gemini"
      }
    },
    {
      "name": "Perplexity practical safety language is flagged",
      "expected": {
        "medium_risk_surfaces_contains": "perplexity"
      }
    },
    {
      "name": "ChatGPT lower-risk framing is summarised",
      "expected": {
        "lower_risk_surfaces_contains": "chatgpt"
      }
    },
    {
      "name": "no SEO content generated",
      "expected": {
        "seo_content_generated": false
      }
    },
    {
      "name": "no Shopify API used",
      "expected": {
        "shopify_api_used": false
      }
    },
    {
      "name": "no auto-publishing",
      "expected": {
        "auto_publish_used": false
      }
    },
    {
      "name": "JSON reports contain no Chinese descriptions",
      "expected": {
        "json_contains_chinese": false
      }
    },
    {
      "name": "Markdown summaries may contain Chinese descriptions",
      "expected": {
        "markdown_chinese_allowed": true
      }
    },
    {
      "name": "does not enter Phase 8H",
      "expected": {
        "phase_8h_generated": false
      }
    }
  ]
}
