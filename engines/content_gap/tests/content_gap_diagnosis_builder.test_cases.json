        "email_copy_generated": false
      }
    },
    {
      "name": "no social video script generated",
      "expected": {
        "social_video_script_generated": false
      }
    },
    {
      "name": "no content opportunity score generated",
      "expected": {
        "content_opportunity_score_generated": false
      }
    },
    {
      "name": "no final visibility score generated",
      "expected": {
        "final_visibility_score_generated": false
      }
    },
    {
      "name": "no AI answers treated as verified facts",
      "expected": {
        "ai_answers_treated_as_verified_fact": false
