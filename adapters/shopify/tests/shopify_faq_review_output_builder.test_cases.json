{
  "test_cases": [
    {
      "name": "clean FAQ export candidate can become Shopify clean candidate only if safe",
      "input": "safe_export_candidate",
      "expected": {
        "shopify_clean_items_greater_than": 0,
        "manual_review_required": true,
        "publish_ready": false
      }
    },
    {
      "name": "blocked FAQ cannot enter Shopify clean output",
      "input": "blocked_item_from_export_pack",
      "expected": {
        "clean_output_excludes_blocked_item": true
      }
    },
    {
      "name": "clean Shopify output contains no Chinese descriptions",
      "input": "shopify_faq_block_clean.md",
      "expected": {
        "contains_chinese": false
      }
    },
    {
      "name": "Shopify review output may contain Chinese descriptions",
      "input": "shopify_faq_block_review.md",
      "expected": {
        "contains_chinese_allowed": true
      }
    },
    {
      "name": "JSON reports contain no Chinese descriptions",
      "input": [
        "shopify_faq_output_report.json",
        "shopify_faq_blocked_items_report.json"
      ],
      "expected": {
        "contains_chinese": false
      }
    },
    {
      "name": "risky claim blocks Shopify clean output",
      "input": "clean_candidate_with_risky_claim",
      "expected": {
        "decision": "blocked",
        "risk_level": "high"
      }
    },
    {
      "name": "unverified shipping warranty certification claim blocks Shopify clean output",
      "input": "clean_candidate_with_unverified_policy_claim",
      "expected": {
        "decision": "blocked"
      }
    },
    {
      "name": "publish_ready remains false",
      "input": "any_phase_6a_output",
      "expected": {
        "publish_ready": false
      }
    },
    {
      "name": "shopify_api_used remains false",
      "input": "any_phase_6a_output",
      "expected": {
        "shopify_api_used": false
      }
    },
    {
      "name": "auto_publish_used remains false",
      "input": "any_phase_6a_output",
      "expected": {
        "auto_publish_used": false
      }
    },
    {
      "name": "live_theme_modified remains false",
      "input": "any_phase_6a_output",
      "expected": {
        "live_theme_modified": false
      }
    },
    {
      "name": "no FAQPage Schema generated",
      "input": "phase_6a_outputs",
      "expected": {
        "faqpage_schema_generated": false
      }
    },
    {
      "name": "no Product Schema generated",
      "input": "phase_6a_outputs",
      "expected": {
        "product_schema_generated": false
      }
    },
    {
      "name": "no final Shopify page generated",
      "input": "phase_6a_outputs",
      "expected": {
        "final_shopify_page_generated": false
      }
    },
    {
      "name": "manual_review_required remains true",
      "input": "any_phase_6a_output",
      "expected": {
        "manual_review_required": true
      }
    }
  ]
}
